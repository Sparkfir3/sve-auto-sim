      m_Calls: []
  m_text: "important notes:\n- online play requires Steam\n- to play locally (LAN),
    one user needs to <i>Start Host</i>, and only after hosting can a second user
    connect using <i>Start Client</i>\n   - you can play against yourself by running
    two instances on one computer and connect using LAN\n- disconnecting will break
    things and you can't reconnect\n- there is no check for if a deck is standard
    or valid\n   - using an illegal deck may or may not break things"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 848f0d04af91d6d4781b27e7b3b2d614, type: 2}
